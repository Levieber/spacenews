{
  "name": "spacenews",
  "version": "1.0.0",
  "description": "An tabnews clone",
  "homepage": "https://github.com/Levieber/spacenews#readme",
  "bugs": {
    "url": "https://github.com/Levieber/spacenews/issues"
  },
  "license": "MIT",
  "author": "Levi Eber <gblevieber@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Levieber/spacenews.git"
  },
  "type": "module",
  "scripts": {
    "predev": "pnpm run services:up && pnpm run services:wait:database && pnpm run migrations:up",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "pretest": "pnpm run services:up",
    "test": "concurrently -n next,test --hide next -k -s command-test \"pnpm:dev\" \"vitest run\"",
    "posttest": "pnpm run services:down",
    "test:watch": "vitest --changed",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "migrations:up:dry": "node-pg-migrate -m infra/migrations --envPath .env.development --dry-run up",
    "lint": "pnpm run \"/^lint:.*:check/\"",
    "lint:write": "pnpm run \"/^lint:.*:write/\"",
    "lint:deps:check": "knip",
    "lint:deps:write": "knip --fix",
    "lint:secret:check": "secretlint \"**/*\"",
    "lint:format:check": "oxfmt --check .",
    "lint:format:write": "oxfmt .",
    "lint:quality:check": "oxlint",
    "lint:quality:write": "oxlint --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "async-retry": "1.3.3",
    "bcryptjs": "3.0.3",
    "cookie": "1.1.1",
    "next": "16.2.7",
    "next-connect": "1.0.0",
    "node-pg-migrate": "8.0.4",
    "nodemailer": "8.0.10",
    "pg": "8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "swr": "2.4.1",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@faker-js/faker": "10.4.0",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "concurrently": "10.0.3",
    "dotenv-expand": "13.0.0",
    "husky": "9.1.7",
    "knip": "6.16.0",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "secretlint": "13.0.2",
    "set-cookie-parser": "3.1.0",
    "vitest": "4.1.8"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24"
    }
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@11.5.2"
}
